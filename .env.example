# smokeping-easy — environment configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and edit the values BEFORE running `docker compose`:
#
#     cp .env.example .env
#
# The `.env` file contains secrets and is git-ignored. Never commit it.
# ---------------------------------------------------------------------------

# --- Ports (host side) -----------------------------------------------------
# Web UI (nginx). Open http://SERVER_IP:3000 after startup.
# In most cases this is the ONLY value you need to change.
HTTP_PORT=3000
# Read-only native Smokeping graphs. Set empty / remove the ports mapping in
# docker-compose.yml to keep Smokeping fully internal.
SMOKEPING_WEB_PORT=8081

# --- User / permissions ----------------------------------------------------
# UID/GID that owns the shared config & data volumes. The backend runs as this
# same user so both containers can write the Targets file. `id -u` / `id -g`.
PUID=1000
PGID=1000

# --- Timezone --------------------------------------------------------------
# Used by Smokeping, the backend scheduler and daily reports.
# e.g. America/Asuncion, America/Mexico_City, Europe/Madrid, UTC
TZ=UTC

# --- First-boot admin password (OPTIONAL) ----------------------------------
# Leave EMPTY to auto-generate a random password on first boot — it is printed
# once in the backend logs (docker compose logs backend | grep -i password).
# If you set it, it seeds the initial password instead. Either way, change it
# from the UI after first login. The plaintext is never written to disk.
ADMIN_PASSWORD=

# --- Internal reload API (OPTIONAL) ----------------------------------------
# The Smokeping reload API listens on an INTERNAL-only port, never published to
# the host. The default (9731) avoids clashing with common services such as
# Portainer/GenieACS (9000). You normally don't need to change this — only if
# you run the stack with network_mode: host and 9731 is already taken.
RELOAD_PORT=9731
# Optional token for defense-in-depth on that internal API. Recommended in
# production:  openssl rand -hex 32
RELOAD_TOKEN=

# --- Session / auth --------------------------------------------------------
# How long a login session stays valid (minutes).
SESSION_TTL_MINUTES=120
# Login rate limit: max failed attempts per IP within the window (minutes).
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=10

# --- Logging ---------------------------------------------------------------
# INFO is the recommended default. DO NOT use DEBUG in production — it is
# noisier and increases the risk of sensitive data ending up in logs.
LOG_LEVEL=INFO

# --- TLS (only for docker-compose.tls.yml) ---------------------------------
# A DNS record (A/AAAA) for this must already point at the server's IP.
# Then run:
#   docker compose -f docker-compose.yml -f docker-compose.tls.yml up -d
DOMAIN=monitor.example.com
ACME_EMAIL=you@example.com
